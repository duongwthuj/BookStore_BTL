# Django settings
DJANGO_SECRET_KEY=your-django-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api-gateway

# JWT settings
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# CORS settings
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Service URLs
AUTH_SERVICE_URL=http://auth-service:8001
CUSTOMER_SERVICE_URL=http://customer-service:8002
STAFF_SERVICE_URL=http://staff-service:8003
MANAGER_SERVICE_URL=http://manager-service:8004
CATALOG_SERVICE_URL=http://catalog-service:8005
BOOK_SERVICE_URL=http://book-service:8006
CART_SERVICE_URL=http://cart-service:8007
ORDER_SERVICE_URL=http://order-service:8008
PAY_SERVICE_URL=http://pay-service:8009
SHIP_SERVICE_URL=http://ship-service:8010
COMMENT_RATE_SERVICE_URL=http://comment-rate-service:8011
RECOMMENDER_SERVICE_URL=http://recommender-service:8012
CHATBOT_SERVICE_URL=http://chatbot-service:8013

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Logging
DJANGO_LOG_LEVEL=INFO
